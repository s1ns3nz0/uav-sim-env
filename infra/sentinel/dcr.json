  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionEndpoints",
      "apiVersion": "2023-03-11",
      "name": "[variables('dceName')]",
      "location": "[parameters('location')]",
      "kind": "Linux",
      "properties": {
        "networkAcls": {
          "publicNetworkAccess": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[variables('dcrName')]",
      "location": "[parameters('location')]",
      "kind": "Linux",
      "properties": {
        "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "streamDeclarations": {
          "[format('{0}', variables('streamName'))]": {
            "columns": "[variables('streamColumns')]"
          }
        },
        "dataSources": {
          "logFiles": [
            {
              "name": "uavTelemetryFile",
              "streams": [
                "[variables('streamName')]"
              ],
              "filePatterns": [
                "[parameters('logFilePath')]"
              ],
              "format": "json"
            }
          ]
        },
        "destinations": {
          "logAnalytics": [
            {
              "name": "centralLaw",
              "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "[variables('streamName')]"
            ],
            "destinations": [
              "centralLaw"
            ],
            "transformKql": "source",
            "outputStream": "[format('Custom-{0}', variables('tableName'))]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]"
      ]
    }
  ],
  "outputs": {
    "dceName": {
      "type": "string",
      "value": "[variables('dceName')]"
    },
    "dceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]"
    },
    "dceIngestEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '2023-03-11').logsIngestion.endpoint]"
    },
    "dcrName": {
      "type": "string",
      "value": "[variables('dcrName')]"
    },
    "dcrId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]"
    },
    "dcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), '2023-03-11').immutableId]"
    },
